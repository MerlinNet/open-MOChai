[gd_resource type="Shader" format=3 uid="uid://daynightshader001"]

[resource]
code = "shader_type canvas_item;
blend_mode multiply;

uniform float current_time : hint_range(0, 1) = 0.0;
uniform float night_intensity : hint_range(0, 1) = 0.85;
uniform float twilight_duration : hint_range(0.05, 0.2) = 0.1;
uniform float sunrise_time : hint_range(0, 1) = 0.25;
uniform float sunset_time : hint_range(0, 1) = 0.75;
uniform float day_intensity : hint_range(0, 0.3) = 0.08;
uniform vec4 night_color : source_color = vec4(0.02, 0.02, 0.08, 1.0);
uniform vec4 twilight_color : source_color = vec4(0.3, 0.15, 0.1, 1.0);
uniform vec4 day_color : source_color = vec4(0.95, 0.93, 0.88, 1.0);

void fragment() {
	vec4 target_color;
	float blend;
	
	if (current_time < sunrise_time - twilight_duration * 0.5) {
		// 深夜
		target_color = night_color;
		blend = night_intensity;
	}
	else if (current_time < sunrise_time + twilight_duration * 0.5) {
		// 黎明过渡
		float t = (current_time - (sunrise_time - twilight_duration * 0.5)) / twilight_duration;
		target_color = mix(night_color, twilight_color, t);
		blend = mix(night_intensity, 0.4, t);
	}
	else if (current_time < sunset_time - twilight_duration * 0.5) {
		// 白天：轻微柔化色调，降低刺眼感
		float t = (current_time - (sunrise_time + twilight_duration * 0.5)) / (sunset_time - sunrise_time - twilight_duration);
		target_color = mix(twilight_color, day_color, min(t * 2.0, 1.0));
		// 正午附近最亮但仍有微弱柔化，早晚稍强
		float noon_factor = 1.0 - abs(t - 0.5) * 2.0;
		blend = day_intensity * (1.0 - noon_factor * 0.5);
	}
	else if (current_time < sunset_time + twilight_duration * 0.5) {
		// 黄昏过渡
		float t = (current_time - (sunset_time - twilight_duration * 0.5)) / twilight_duration;
		target_color = mix(day_color, twilight_color, t);
		blend = mix(day_intensity, night_intensity * 0.6, t);
	}
	else {
		// 入夜过渡
		float t = (current_time - (sunset_time + twilight_duration * 0.5)) / (1.0 - sunset_time - twilight_duration * 0.5);
		target_color = mix(twilight_color, night_color, min(t * 2.0, 1.0));
		blend = mix(night_intensity * 0.6, night_intensity, t);
	}
	
	COLOR = vec4(target_color.rgb, blend);
}
"
